// ============================================================================
//  SalonOS — Prisma schema
//  Multi-tenant model: shared database, row-level isolation via `tenantId`.
//  Every tenant-owned table carries `tenantId` and is queried through a
//  tenant-scoped Prisma client (see packages/database/src/tenant.ts).
//  See docs/MULTI-TENANCY.md for the full strategy and trade-offs.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
//  Enums
// ----------------------------------------------------------------------------

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
}

enum Role {
  SUPER_ADMIN // platform operator (no tenant)
  OWNER
  MANAGER
  STAFF
  RECEPTIONIST
  CLIENT
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  ONLINE
  WALK_IN
  PHONE
  ADMIN
}

enum SaleStatus {
  OPEN
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOID
}

enum SaleItemType {
  SERVICE
  PRODUCT
}

enum PaymentMethod {
  CARD
  CASH
  WALLET
  BANK_TRANSFER
  GIFT_CARD
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentPurpose {
  SALE
  SUBSCRIPTION
  DEPOSIT
}

enum DiscountType {
  PERCENT
  FIXED
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

// ----------------------------------------------------------------------------
//  Platform / tenant
// ----------------------------------------------------------------------------

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique // subdomain: <slug>.salonos.app
  customDomain String?      @unique
  status       TenantStatus @default(TRIAL)
  plan         Plan         @default(STARTER)

  // Localization (defaults; per-location can override timezone)
  locale       String       @default("en")    // en | ur | ar | ...
  currency     String       @default("USD")   // ISO 4217
  timezone     String       @default("UTC")   // IANA tz

  // Branding (drives white-label theming of the booking site & emails)
  logoUrl      String?
  primaryColor String       @default("#7C3AED")
  tagline      String?

  // Booking-site customization (white-label public page)
  coverImageUrl String?
  about         String?
  phone         String?
  address       String?
  instagramUrl  String?
  facebookUrl   String?
  whatsapp      String?
  bookingEnabled Boolean     @default(true)

  // Stripe
  stripeCustomerId String? @unique // billed for the SaaS subscription
  stripeAccountId  String? @unique // Stripe Connect account (receives client payments)

  trialEndsAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscription Subscription?
  locations    Location[]
  users        User[]
  staff        StaffProfile[]
  serviceCategories ServiceCategory[]
  services     Service[]
  clients      Client[]
  appointments Appointment[]
  products     Product[]
  sales        Sale[]
  payments     Payment[]
  discounts    Discount[]
  reviews      Review[]
  notifications Notification[]
  auditLogs    AuditLog[]

  @@index([status])
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan               @default(STARTER)
  status               SubscriptionStatus @default(TRIALING)
  stripeSubscriptionId String?            @unique
  seats                Int                @default(5)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  address   String?
  city      String?
  country   String?
  timezone  String?  // overrides tenant.timezone when set
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff        StaffProfile[]
  appointments Appointment[]
  sales        Sale[]

  @@index([tenantId])
}

// ----------------------------------------------------------------------------
//  Identity & access
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  tenantId     String?    // null only for SUPER_ADMIN
  tenant       Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String?
  name         String
  phone        String?
  role         Role       @default(STAFF)
  status       UserStatus @default(ACTIVE)
  locale       String     @default("en")
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  staffProfile  StaffProfile?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model StaffProfile {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  title          String?  // "Senior Stylist"
  bio            String?
  color          String   @default("#0EA5E9") // calendar colour
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // percent
  isBookable     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services         Service[]          @relation("StaffServices")
  workingHours     WorkingHours[]
  timeOff          TimeOff[]
  appointmentItems AppointmentItem[]
  saleItems        SaleItem[]
  reviews          Review[]

  @@index([tenantId])
}

model WorkingHours {
  id        String   @id @default(cuid())
  staffId   String
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday .. 6 = Saturday
  startMin  Int      // minutes from midnight, e.g. 540 = 09:00
  endMin    Int      // e.g. 1020 = 17:00

  @@index([staffId])
}

model TimeOff {
  id        String   @id @default(cuid())
  staffId   String
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?

  @@index([staffId])
}

// ----------------------------------------------------------------------------
//  Catalogue: services & products
// ----------------------------------------------------------------------------

model ServiceCategory {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  services  Service[]

  @@index([tenantId])
}

model Service {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       ServiceCategory? @relation(fields: [categoryId], references: [id])
  name           String
  description    String?
  durationMin    Int      @default(30)
  bufferBeforeMin Int     @default(0)
  bufferAfterMin  Int     @default(0)
  price          Decimal  @db.Decimal(10, 2)
  color          String   @default("#7C3AED")
  imageUrl       String?
  onlineBookable Boolean  @default(true)
  depositRequired Boolean @default(false)
  depositAmount  Decimal? @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staff            StaffProfile[]    @relation("StaffServices")
  appointmentItems AppointmentItem[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  description String?
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2)
  stockQty    Int      @default(0)
  lowStockAt  Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements InventoryMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([productId])
}

// ----------------------------------------------------------------------------
//  CRM: clients
// ----------------------------------------------------------------------------

model Client {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  notes         String?
  tags          String[] @default([])
  loyaltyPoints Int      @default(0)
  marketingOptIn Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments Appointment[]
  sales        Sale[]
  reviews      Review[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

// ----------------------------------------------------------------------------
//  Bookings
// ----------------------------------------------------------------------------

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  status      AppointmentStatus @default(PENDING)
  source      BookingSource     @default(ONLINE)
  startsAt    DateTime
  endsAt      DateTime
  notes       String?
  total       Decimal  @default(0) @db.Decimal(10, 2)
  cancelledAt DateTime?
  cancelReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items AppointmentItem[]
  sale  Sale?

  @@index([tenantId, startsAt])
  @@index([tenantId, status])
}

model AppointmentItem {
  id            String   @id @default(cuid())
  appointmentId String
  appointment   Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  staffId       String?
  staff         StaffProfile? @relation(fields: [staffId], references: [id])
  startsAt      DateTime
  endsAt        DateTime
  price         Decimal  @db.Decimal(10, 2)
  durationMin   Int

  @@index([appointmentId])
  @@index([staffId, startsAt])
}

// ----------------------------------------------------------------------------
//  Sales / POS
// ----------------------------------------------------------------------------

model Sale {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  number        Int      @default(autoincrement())
  status        SaleStatus @default(OPEN)
  subtotal      Decimal  @default(0) @db.Decimal(10, 2)
  discountTotal Decimal  @default(0) @db.Decimal(10, 2)
  taxTotal      Decimal  @default(0) @db.Decimal(10, 2)
  tipTotal      Decimal  @default(0) @db.Decimal(10, 2)
  total         Decimal  @default(0) @db.Decimal(10, 2)
  currency      String   @default("USD")
  discountId    String?
  discount      Discount? @relation(fields: [discountId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items    SaleItem[]
  payments Payment[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  type      SaleItemType
  refId     String?  // serviceId or productId
  name      String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  staffId   String?
  staff     StaffProfile? @relation(fields: [staffId], references: [id])

  @@index([saleId])
}

model Payment {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleId                String?
  sale                  Sale?    @relation(fields: [saleId], references: [id])
  purpose               PaymentPurpose @default(SALE)
  method                PaymentMethod  @default(CARD)
  status                PaymentStatus  @default(PENDING)
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("USD")
  refundedAmount        Decimal  @default(0) @db.Decimal(10, 2)
  stripePaymentIntentId String?  @unique
  receiptUrl            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, createdAt])
}

// ----------------------------------------------------------------------------
//  Marketing: discounts, loyalty, reviews
// ----------------------------------------------------------------------------

model Discount {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code       String
  type       DiscountType
  value      Decimal  @db.Decimal(10, 2)
  validFrom  DateTime?
  validUntil DateTime?
  usageLimit Int?
  usageCount Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  sales Sale[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Review {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  staffId       String?
  staff         StaffProfile? @relation(fields: [staffId], references: [id])
  rating        Int      // 1..5
  comment       String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

// ----------------------------------------------------------------------------
//  System: notifications, audit, webhooks
// ----------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  template  String
  payload   Json
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // e.g. "appointment.created"
  entity    String?
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Stripe webhook idempotency / event log
model WebhookEvent {
  id          String   @id // Stripe event id
  type        String
  processedAt DateTime @default(now())
  payload     Json
}
