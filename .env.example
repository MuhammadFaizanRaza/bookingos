# ============================================================================
#  SalonOS — Environment configuration
#  Copy this file to `.env` (root) and fill in the values.
#  `pnpm setup` reads from here.
# ============================================================================

# ---- Database (PostgreSQL) -------------------------------------------------
POSTGRES_USER=salonos
POSTGRES_PASSWORD=salonos
POSTGRES_DB=salonos
DATABASE_URL=postgresql://salonos:salonos@localhost:5432/salonos?schema=public

# ---- Cache / Queues (Redis) ------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- API (NestJS) ----------------------------------------------------------
API_PORT=4000
NODE_ENV=development

# JWT auth — generate strong secrets in production (openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Public base URL of the API (used in emails, webhooks, etc.)
API_PUBLIC_URL=http://localhost:4000

# ---- Multi-tenancy ---------------------------------------------------------
# Root domain used to resolve tenants by subdomain, e.g. acme.salonos.app
ROOT_DOMAIN=salonos.local
# Comma-separated list of reserved subdomains that are never tenants
RESERVED_SUBDOMAINS=www,app,api,admin,book,assets

# ---- Stripe (payments + SaaS subscription billing) -------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Connect (so each salon receives money into its own account)
STRIPE_CONNECT_CLIENT_ID=ca_xxx
# Platform subscription price IDs (SaaS plans you sell to salons)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# ---- Email (transactional) -------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="SalonOS <no-reply@salonos.app>"

# ---- SMS / WhatsApp reminders (optional, Twilio) ---------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- File storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO) ----------
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=salonos-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Web (Next.js) ---------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_DEFAULT_LOCALE=en
